# Runtime
NODE_ENV=development
PORT=3000
DATABASE_PATH=./agent.db

# LLMs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# Market API
POLYMARKET_API_BASE_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=

# Trading mode
PAPER_TRADING=true
STARTING_BANKROLL_USD=10000
AGENT_LOOP_INTERVAL_MS=30000

# Risk controls
MIN_EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.5
MAX_POSITION_PCT=0.1
MAX_PORTFOLIO_EXPOSURE_PCT=0.5
STOP_LOSS_PCT=0.2

# Data ingestion
NEWS_RSS_FEEDS=https://feeds.reuters.com/reuters/worldNews,https://rss.cnn.com/rss/edition.rss
REDDIT_SUBREDDITS=news,politics,worldnews
EVENT_CALENDAR_API_URL=
